# ═══════════════════════════════════════════════════════════════
# .gitignore — Pipeline RAG
# ═══════════════════════════════════════════════════════════════

# ── Environnement virtuel ────────────────────────────────────
venv/
.venv/
env/

# ── Variables d'environnement (clés API, secrets) ────────────
.env
.env.*

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / Build ────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── Jupyter Notebooks ───────────────────────────────────────
.ipynb_checkpoints/

# ── IDE / Éditeurs ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Données générées par le pipeline ────────────────────────
data/
outputs/

# ── Fichiers binaires / modèles ─────────────────────────────
*.faiss
*.pkl
*.npy
*.npz
*.bin
*.pt
*.onnx
